NODE_ENV=development
APP_NAME=Stack62 Backend
PORT=3000
API_PREFIX=v1
CORS_ORIGIN=*

# Production must use a unique secret, DATABASE_SYNC=false, and explicit CORS origins.
JWT_SECRET=stack62-local-development-secret
JWT_EXPIRES_IN=1d

DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=stack62
DATABASE_SYNC=true
DATABASE_LOGGING=false
DATABASE_SSL=false

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
# BullMQ requires Redis 7 or a compatible managed Redis plan with Lua scripting.
REDIS_SKIP_VERSION_CHECK=true

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_APP_NAME=Stack62 Studio Engine
OPENROUTER_HTTP_REFERER=
AI_ENABLE_REMOTE_PLANNER=true
AI_PROVIDER=anthropic
AI_DEFAULT_MODEL=claude-code:sonnet
AI_REQUIRE_APPROVAL=true
AI_INCLUDED_MONTHLY_CREDITS=100

# Provider credentials. Never commit real values; rotate keys before production if pasted/shared.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
META_WHATSAPP_ACCESS_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=
# User sign-in integrations. These are developer OAuth app credentials for Stack62;
# end users still connect by signing in and granting consent in the browser.
# Generate your own from: console.cloud.google.com / developers.facebook.com /
# developer.intuit.com — never commit real values.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:5173/oauth/callback/google
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://127.0.0.1:5173/oauth/callback/meta
META_WHATSAPP_CONFIGURATION_ID=
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REDIRECT_URI=http://127.0.0.1:5173/oauth/callback/quickbooks
QUICKBOOKS_ENVIRONMENT=sandbox
MICROSOFT_365_TENANT_ID=
MICROSOFT_365_CLIENT_ID=
MICROSOFT_365_CLIENT_SECRET=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
PAYSTACK_CALLBACK_URL=

GENERATED_APPS_BASE_DOMAIN=stack62.loopital.com
RUNNER_SANDBOX_MODE=process
RUNNER_DOCKER_IMAGE=node:20-bookworm-slim
RUNNER_DOCKER_NETWORK=bridge
RUNNER_DOCKER_CPUS=0.5
RUNNER_DOCKER_PIDS_LIMIT=128
RUNNER_ALLOWED_DEPENDENCIES=express,better-sqlite3
RUNNER_PROCESS_TIMEOUT_MS=1800000
RUNNER_NODE_MAX_OLD_SPACE_MB=128

WORKFLOW_AUTOMATION_ENABLED=true
WORKFLOW_AUTOMATION_INTERVAL_MS=15000

AUDIT_EXPORT_MAX_ROWS=5000
SECURITY_REQUIRE_2FA_FOR_ADMINS=true
SECURITY_ENABLE_IP_ALLOWLIST=false
SECURITY_DATA_RETENTION_DAYS=2555
SECURITY_SSO_REQUIRED=false

THROTTLE_TTL=60
THROTTLE_LIMIT=60
